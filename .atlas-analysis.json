  "keyFeatures": [
    "Hardware-level microVM isolation using Firecracker/QEMU",
    "Sub-second boot times with minimal overhead",
    "Python-native SDK with context manager support",
    "Automatic networking with NAT and port forwarding",
    "SSH-ready environments for command execution",
    "Custom rootfs image builder",
    "Environment variable injection",
    "Cross-platform support (Linux Firecracker, macOS QEMU)",
    "Reconnectable VM sessions",
    "Built-in diagnostics and cleanup tools"
  ],
  "publicApiSurface": [
